# Ignore tests and irrelevant sources inside dist/
dist/test/
dist/tests/
dist/**/*.test.js
dist/**/*.test.d.ts
dist/**/*.spec.js
dist/**/*.spec.d.ts
dist/benchmarks/
dist/test-production-app/
dist/src/
dist/visual/
dist/test-server.js
dist/test-server.d.ts
dist/templates/starters/*.d.ts

# General ignores
node_modules/
tests/
benchmarks/
.github/
docs/
examples/
urja-web-app/
lunx-web-app/
src/
scripts/
packages/
Cargo.toml
Cargo.lock
target/
.gitignore
.prettierrc
tsconfig.json
tsconfig.*.json
jest.config.js
.eslintrc.js

# Exclude massive platform-specific Rust binaries from the main package (keeps size < 2MB).
# Users without the binary will gracefully fall back to the JS stub implemented in index.js.
dist/lunx_native.node
dist/**/*.node
dist/nexxo_native.node
nexxo_native.node
**/*.node
*.node
dist/**/__tests__/
