---
const guides = ['Installation', 'Configuration', 'Adapters', 'Plugins', 'Security'];
const references = ['API Reference', 'CLI Reference', 'Config Reference'];
const features = [
  { icon: '⚡', title: 'Sub-10ms HMR', desc: 'Rust-powered file watcher with WebSocket transport.' },
  { icon: '🏝️', title: 'Astro Islands', desc: 'Ship zero JS by default, hydrate only what you need.' },
  { icon: '📝', title: 'Content Collections', desc: 'Type-safe content with SQLite-backed caching.' },
  { icon: '🚀', title: 'Static & SSR', desc: 'Output HTML, Hybrid, or Server — your choice.' },
  { icon: '🔒', title: 'Security Gate', desc: 'Built-in CVE scanning, CSP, and secret detection.' },
  { icon: '🦀', title: 'Rust Native Core', desc: 'esbuild + Rust for the fastest possible cold start.' },
];
---
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title>Astro + Lunx</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet"/>
  <style>
    *{margin:0;padding:0;box-sizing:border-box}
    :root{--bg:#030712;--surface:#0d1526;--border:#1e2d45;--primary:#6366f1;--accent:#818cf8;--astro:#ff5d01}
    body{background:var(--bg);color:#f1f5f9;font-family:'Inter',system-ui,sans-serif;min-height:100vh;display:flex;overflow-x:hidden}
    body::before{content:'';position:fixed;inset:0;background:radial-gradient(ellipse 80% 50% at 50% -20%,#ff5d0130,transparent),radial-gradient(ellipse 60% 40% at 80% 80%,#6366f120,transparent);pointer-events:none;z-index:0}
    body::after{content:'';position:fixed;inset:0;background-image:linear-gradient(rgba(99,102,241,.03) 1px,transparent 1px),linear-gradient(90deg,rgba(99,102,241,.03) 1px,transparent 1px);background-size:40px 40px;pointer-events:none;z-index:0}
    /* Sidebar */
    aside{width:260px;min-height:100vh;background:rgba(13,21,38,.9);border-right:1px solid #1e2d45;padding:28px 20px;position:sticky;top:0;height:100vh;overflow-y:auto;flex-shrink:0;backdrop-filter:blur(12px);z-index:1}
    .logo{display:flex;align-items:center;gap:10px;margin-bottom:36px;text-decoration:none}
    .logo-icon{width:36px;height:36px;background:linear-gradient(135deg,#ff5d01,#ff8c00);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:18px}
    .logo-text{font-weight:800;font-size:17px;color:#f1f5f9}
    .logo-badge{font-size:10px;background:#6366f115;border:1px solid #6366f133;color:#818cf8;padding:2px 7px;border-radius:999px;margin-left:4px;font-weight:600}
    .nav-section{font-size:10px;text-transform:uppercase;letter-spacing:2px;color:#475569;font-weight:700;margin:20px 0 8px}
    .nav-section:first-of-type{margin-top:0}
    aside a{display:block;padding:7px 12px;border-radius:8px;font-size:13px;color:#94a3b8;text-decoration:none;transition:.2s;margin-bottom:2px}
    aside a:hover{background:#1e2d45;color:#f1f5f9}
    aside a.active{background:#6366f120;color:#818cf8;border:1px solid #6366f133}
    .sidebar-footer{margin-top:auto;padding-top:24px;border-top:1px solid #1e2d45;font-size:11px;color:#334155}
    .sidebar-footer span{color:#6366f1;font-weight:600}
    /* Main */
    main{flex:1;padding:60px 64px;max-width:900px;position:relative;z-index:1}
    .lunx-pill{display:inline-flex;align-items:center;gap:8px;background:rgba(99,102,241,.12);border:1px solid rgba(99,102,241,.3);border-radius:999px;padding:5px 14px;font-size:12px;font-weight:600;color:#818cf8;margin-bottom:24px}
    h1{font-size:clamp(40px,5vw,64px);font-weight:900;line-height:1.05;letter-spacing:-2px;margin-bottom:16px}
    h1 .lunx{background:linear-gradient(135deg,#e0e7ff,#818cf8);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
    h1 .astro{background:linear-gradient(135deg,#ff5d01,#ffad00);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
    .subtitle{color:#94a3b8;font-size:17px;line-height:1.7;max-width:600px;margin-bottom:36px}
    .meta-row{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:56px}
    .chip{background:rgba(13,21,38,.8);border:1px solid #1e2d45;border-radius:10px;padding:10px 16px;font-size:13px;color:#64748b}
    .chip strong{color:#f1f5f9;display:block;font-size:14px;margin-bottom:2px}
    /* Features */
    .section-label{font-size:11px;text-transform:uppercase;letter-spacing:3px;color:#818cf8;font-weight:700;margin-bottom:20px;display:flex;align-items:center;gap:12px}
    .section-label::after{content:'';flex:1;height:1px;background:linear-gradient(90deg,#1e2d45,transparent)}
    .grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:14px;margin-bottom:48px}
    .card{background:rgba(13,21,38,.8);border:1px solid #1e2d45;border-radius:14px;padding:22px;transition:.25s;backdrop-filter:blur(8px)}
    .card:hover{border-color:#6366f155;transform:translateY(-2px);box-shadow:0 16px 32px rgba(0,0,0,.3)}
    .card-icon{width:40px;height:40px;background:#ff5d0115;border:1px solid #ff5d0133;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:20px;margin-bottom:14px}
    .card h3{font-size:14px;font-weight:700;margin-bottom:6px;color:#e2e8f0}
    .card p{font-size:12px;color:#64748b;line-height:1.7}
    /* Terminal */
    .term{background:#020817;border:1px solid #1e2d45;border-radius:14px;padding:22px;margin-bottom:48px;position:relative;overflow:hidden}
    .term::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,#ff5d0155,transparent)}
    .th{display:flex;align-items:center;gap:6px;margin-bottom:18px}
    .dot{width:12px;height:12px;border-radius:50%}
    .ln{font-size:13px;line-height:2.2;font-family:'Courier New',monospace}
    .p{color:#334155}.cmd{color:#818cf8}.ok{color:#22c55e}.dim{color:#475569}.cmt{color:#334155}
    footer{border-top:1px solid #1e2d45;padding:24px 0;margin-top:16px;font-size:12px;color:#334155;display:flex;gap:16px}
    footer a{color:#6366f1;text-decoration:none}
    footer a:hover{color:#818cf8}
    @keyframes fadeUp{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
    main>*{animation:fadeUp .5s ease both}
    .meta-row{animation-delay:.1s}.grid{animation-delay:.2s}.term{animation-delay:.3s}
  </style>
</head>
<body>
  <aside>
    <a href="/" class="logo">
      <div class="logo-icon">🚀</div>
      <div>
        <div class="logo-text">Lunx Docs <span class="logo-badge">Astro</span></div>
      </div>
    </a>
    <div class="nav-section">Guide</div>
    {guides.map(g => <a href={`/guide/${g.toLowerCase()}`}>{g}</a>)}
    <div class="nav-section">Reference</div>
    {references.map(r => <a href={`/api/${r.toLowerCase().replace(/ /g,'-')}`}>{r}</a>)}
    <div class="nav-section">Resources</div>
    <a href="#">GitHub</a>
    <a href="#">Changelog</a>
    <div class="sidebar-footer">
      <div>⚡ <span>Lunx</span> v1.0.10</div>
      <div>🚀 Astro v4.10.2</div>
    </div>
  </aside>

  <main>
    <div class="lunx-pill">⚡ Lunx Build Tool &nbsp;·&nbsp; 🚀 Astro Adapter</div>
    <h1>
      <span class="astro">Astro</span> + <span class="lunx">Lunx</span>
    </h1>
    <p class="subtitle">
      Islands architecture for content-driven websites — zero JS by default,
      powered by Lunx's Rust-native build engine and intelligent dependency caching.
    </p>
    <div class="meta-row">
      <div class="chip"><strong>🚀 Astro v4.10.2</strong>Framework</div>
      <div class="chip"><strong>⚡ Lunx Engine</strong>Build Tool</div>
      <div class="chip"><strong>🏝️ Islands</strong>Architecture</div>
      <div class="chip"><strong>🦀 Rust Native</strong>Core Engine</div>
    </div>

    <div class="section-label">Framework Features</div>
    <div class="grid">
      {features.map(f => (
        <div class="card">
          <div class="card-icon">{f.icon}</div>
          <h3>{f.title}</h3>
          <p>{f.desc}</p>
        </div>
      ))}
    </div>

    <div class="section-label">Quick Start</div>
    <div class="term">
      <div class="th">
        <div class="dot" style="background:#ef4444"></div>
        <div class="dot" style="background:#f59e0b"></div>
        <div class="dot" style="background:#22c55e"></div>
      </div>
      <div class="ln"><span class="cmt"># Create an Astro project with Lunx</span></div>
      <div class="ln"><span class="p">$ </span><span class="cmd">lunx create my-docs --framework astro</span></div>
      <div class="ln"><span class="ok">  ✓ Scaffolded Astro project in 0.3s</span></div>
      <div class="ln"><span class="p">$ </span><span class="cmd">lunx dev</span></div>
      <div class="ln"><span class="ok">  ✓ Compiled!</span> <span class="dim">→ http://localhost:5173</span></div>
      <div class="ln"><span class="p">$ </span><span class="cmd">lunx build --optimize</span></div>
      <div class="ln"><span class="ok">  ✓ Build complete — 42 static pages generated in 1.2s</span></div>
    </div>

    <footer>
      <span>Built with ⚡ <a href="#">Lunx</a> + 🚀 <a href="#">Astro</a></span>
      <a href="#">Documentation</a>
      <a href="#">GitHub</a>
      <a href="#">Changelog</a>
    </footer>
  </main>
</body>
</html>
