{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "declaration": true,
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "isolatedModules": true,
    "paths": {
      "@zeptr/adapter-core": ["./packages/zeptr-adapter-core/src/index.js", "./packages/zeptr-adapter-core/src/index.ts"],
      "@zeptr/adapter-core/*": ["./packages/zeptr-adapter-core/*"],
      "@zeptr/security": ["./packages/zeptr-security/src/index.ts"],
      "@zeptr/security/*": ["./packages/zeptr-security/src/*"]
    }
  },
  "include": [
    "src/**/*",
    "extensions/**/*",
    "packages/**/*"
  ],
  "exclude": [
    "tests/**",
    "benchmarks/**",
    "**/node_modules/**",
    "dist/**",
    "e2e/**"
  ]
}