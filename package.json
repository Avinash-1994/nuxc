{
  "name": "nuxco",
  "version": "1.0.0",
  "description": "⚡ Nuxco — a modern JavaScript build tool powered by SWC and LightningCSS. Fast HMR, module federation, tree shaking, and multi-framework support (React, Vue, Svelte, Solid). A fast, Rust-native build pipeline.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json",
    "./dist/*": "./dist/*"
  },
  "sideEffects": false,
  "bin": {
    "nuxco": "./dist/cli.js",
    "create-nuxco": "./dist/create-nuxco.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rimraf dist && npm run build:native && tsc -p tsconfig.build.json && node ./scripts/postbuild.js",
    "build:native": "node ./scripts/build_native.js",
    "dev": "bun src/cli.ts dev",
    "dev:bun": "bun src/cli.ts dev",
    "start": "bun src/cli.ts dev",
    "prepack": "npm run build",
    "test": "cross-env NODE_OPTIONS=\"--experimental-vm-modules\" jest",
    "test:bun": "bun test",
    "test:repro": "node ./scripts/repro_test.mjs",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "typecheck:build": "tsc -p tsconfig.build.json --noEmit",
    "test:all": "tsc -p tsconfig.build.json && npx tsx tests/config_test.ts && npx tsx tests/bootstrap_test.ts && npx tsx tests/integration_test.ts && npx tsx tests/asset_test.ts && npx tsx tests/federation_core_test.ts && npx tsx tests/core_engine_test.ts && npx tsx tests/framework_verification_test.ts && npx tsx tests/phase_3_1_hmr_classification_test.ts && npx tsx tests/phase_3_1_hmr_integration_test.ts",
    "test:regression": "npx tsx src/test/regression.ts",
    "test:snapshot": "cross-env NODE_OPTIONS=\"--experimental-vm-modules\" jest tests/build/snapshot.test.ts",
    "test:performance": "cross-env NODE_OPTIONS=\"--experimental-vm-modules\" jest tests/performance/regression.test.ts --testTimeout=30000",
    "test:real-world": "cross-env NODE_OPTIONS=\"--experimental-vm-modules\" jest tests/real-world/integration.test.ts --testTimeout=60000",
    "test:foundation": "npm run test:snapshot && npm run test:performance && npm run test:real-world",
    "test:css": "cross-env NODE_OPTIONS=\"--experimental-vm-modules\" jest tests/css/processing.test.ts --testTimeout=30000",
    "test:federation": "cross-env NODE_OPTIONS=\"--experimental-vm-modules\" jest tests/federation/module-federation.test.ts --testTimeout=30000",
    "test:cache": "cross-env NODE_OPTIONS=\"--experimental-vm-modules\" jest tests/cache/correctness.test.ts --testTimeout=30000",
    "test:errors": "cross-env NODE_OPTIONS=\"--experimental-vm-modules\" jest tests/errors/handling.test.ts --testTimeout=30000",
    "test:comprehensive": "npm run test:css && npm run test:federation && npm run test:cache && npm run test:errors",
    "test:phase2": "npm run test:foundation && npm run test:comprehensive",
    "test:property": "cross-env NODE_OPTIONS=\"--experimental-vm-modules\" jest tests/property/ --testTimeout=60000",
    "test:load": "cross-env NODE_OPTIONS=\"--experimental-vm-modules\" jest tests/load/stress.test.ts --testTimeout=300000",
    "test:visual": "playwright test tests/visual/regression.test.ts",
    "test:advanced": "npm run test:property && npm run test:load",
    "test:phase3": "npm run test:phase2 && npm run test:advanced",
    "audit:api-surface": "npx tsx scripts/audit/api-surface.ts",
    "audit:plugin-contract": "npx tsx scripts/audit/plugin-contract.ts",
    "audit:all": "npx tsx scripts/audit/run-all.ts",
    "governance:check": "npm run audit:all",
    "lint": "eslint src/**/*.ts tests/**/*.ts",
    "dev:mfe": "node --no-warnings ./dist/cli.js dev --all ./real-world-mfe",
    "portal": "node --no-warnings ./dist/cli.js dev --all ./portal"
  },
  "keywords": [
    "build-tool",
    "bundler",
    "hmr",
    "hot-reload",
    "hot-module-replacement",
    "source-maps",
    "tree-shaking",
    "module-federation",
    "micro-frontend",
    "react",
    "vue",
    "svelte",
    "solid",
    "qwik",
    "preact",
    "typescript",
    "dev-server",
    "fast",
    "performance",
    "swc",
    "lightningcss",
    "rust",
    "vite-alternative",
    "webpack-alternative",
    "rspack-alternative",
    "fast-bundler",
    "javascript-bundler",
    "esm",
    "es-modules",
    "postcss",
    "css-modules",
    "tailwind",
    "turbopack-alternative",
    "esbuild-alternative",
    "rollup-alternative"
  ],
  "author": "Avinash-1994",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Avinash-1994/nuxco.git"
  },
  "bugs": {
    "url": "https://github.com/Avinash-1994/nuxco/issues"
  },
  "homepage": "https://github.com/Avinash-1994/nuxco#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@babel/core": "^7.28.5",
    "@babel/plugin-transform-modules-commonjs": "^7.27.1",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@node-rs/xxhash": "^1.7.6",
    "@nuxco/adapter-core": "file:packages/nuxco-adapter-core",
    "@nuxco/security": "file:packages/nuxco-security",
    "@swc/core": "^1.15.24",
    "@tauri-apps/api": "^2.11.0",
    "@trpc/client": "^11.8.1",
    "@trpc/server": "^11.8.1",
    "@types/level": "^6.0.3",
    "@vue/compiler-sfc": "^3.5.26",
    "@vue/server-renderer": "^3.5.26",
    "acorn": "^8.15.0",
    "axe-core": "^4.11.1",
    "babel-preset-solid": "^1.8.0",
    "better-sqlite3": "^12.9.0",
    "chalk": "^5.6.2",
    "chokidar": "^3.5.3",
    "dotenv": "^17.2.3",
    "esbuild": "^0.27.2",
    "esbuild-svelte": "^0.9.4",
    "http-proxy": "^1.18.1",
    "ink": "^6.6.0",
    "ink-spinner": "^5.0.0",
    "js-yaml": "^4.1.1",
    "kleur": "^4.1.4",
    "launch-editor": "^2.12.0",
    "level": "^10.0.0",
    "node-fetch": "^2.7.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-refresh": "^0.18.0",
    "rimraf": "^6.1.2",
    "rxjs": "^7.8.2",
    "selfsigned": "^5.5.0",
    "svelte-preprocess": "^6.0.3",
    "uWebSockets.js": "github:uNetworking/uWebSockets.js#v20.43.0",
    "vue": "^3.5.26",
    "ws": "^8.18.3",
    "yargs": "^17.7.2",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.4.1",
    "@napi-rs/triples": "^2.1.4",
    "@playwright/test": "^1.58.0",
    "@types/babel__core": "^7.20.5",
    "@types/better-sqlite3": "^7.6.13",
    "@types/http-proxy": "^1.17.17",
    "@types/ink": "^0.5.2",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^20.3.1",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@types/selfsigned": "^2.0.4",
    "@types/three": "^0.182.0",
    "@types/ws": "^8.5.4",
    "@typescript-eslint/eslint-plugin": "^8.51.0",
    "@typescript-eslint/parser": "^8.51.0",
    "autocannon": "^8.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.2",
    "eslint-plugin-nuxco-governance": "file:eslint-plugin-nuxco-governance",
    "fast-check": "^4.5.3",
    "jest": "^30.2.0",
    "jsdom": "^27.2.0",
    "pixelmatch": "^7.1.0",
    "playwright": "^1.58.2",
    "pngjs": "^7.0.0",
    "puppeteer": "^24.34.0",
    "rolldown": "^1.0.0-rc.1",
    "rollup": "^4.55.1",
    "svelte": "^5.43.14",
    "three": "^0.182.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.1",
    "tsx": "^4.21.0",
    "typescript": "^5.4.2"
  }
}
